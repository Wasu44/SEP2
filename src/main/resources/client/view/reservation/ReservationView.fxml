<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.client.view.reservation.ReservationViewController"
      spacing="10" prefWidth="700" prefHeight="460">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <Label fx:id="titleLabel" text="Reservations" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <TableView fx:id="reservationsTable" prefHeight="280">
        <columns>
            <TableColumn fx:id="idColumn" text="ID" prefWidth="40"/>
            <TableColumn fx:id="listingColumn" text="Listing" prefWidth="200"/>
            <TableColumn fx:id="customerColumn" text="Customer" prefWidth="180"/>
            <TableColumn fx:id="statusColumn" text="Status" prefWidth="120"/>
        </columns>
    </TableView>

    <HBox spacing="10">
        <Button fx:id="confirmButton" text="Confirm" onAction="#handleConfirm"/>
        <Button fx:id="rejectButton" text="Reject" onAction="#handleReject"/>
        <Button fx:id="pickupButton" text="Confirm pickup" onAction="#handleCompletePickup"/>
        <Button text="Refresh" onAction="#handleRefresh"/>
        <Button text="Back" onAction="#handleBack"/>
    </HBox>

    <Label fx:id="errorLabel" textFill="red" wrapText="true"/>
    <Label fx:id="infoLabel" textFill="green" wrapText="true"/>
</VBox>
