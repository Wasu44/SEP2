<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.geometry.Insets?>


<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.client.view.login.LoginViewController"
      styleClass="login-root"
      stylesheets="@LoginView.css"
      spacing="10">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <Label text="Login" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
    <TextField fx:id="emailField" promptText="Email"/>
    <PasswordField fx:id="passwordField" promptText="Password"/>
    <Button text="Sign In" onAction="#handleLogin"/>
    <Hyperlink fx:id="hyperlinkRegister" text="No account? Register here" onAction="#handleGoToRegister"/>
    <Label fx:id="errorLabel" textFill="red" wrapText="true"/>
</VBox>
