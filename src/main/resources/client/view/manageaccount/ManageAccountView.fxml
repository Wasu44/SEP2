<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.client.view.manageaccount.ManageAccountViewController"
      spacing="10" prefWidth="360">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <Label text="Manage account" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <Label text="Name"/>
    <TextField fx:id="nameField"/>

    <Label text="Email"/>
    <TextField fx:id="emailField"/>

    <Label text="New password (leave empty to keep current)"/>
    <PasswordField fx:id="passwordField"/>

    <Button text="Save changes" onAction="#handleSave" maxWidth="Infinity"/>
    <Button text="Back" onAction="#handleBack" maxWidth="Infinity"/>

    <Label fx:id="errorLabel" textFill="red" wrapText="true"/>
    <Label fx:id="infoLabel" textFill="green" wrapText="true"/>
</VBox>
