<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.client.view.adminverification.AdminVerificationViewController"
      spacing="10" prefWidth="640" prefHeight="420">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <Label text="Pending provider verifications" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <TableView fx:id="providersTable" prefHeight="260">
        <columns>
            <TableColumn fx:id="idColumn" text="ID" prefWidth="40"/>
            <TableColumn fx:id="emailColumn" text="Email" prefWidth="220"/>
            <TableColumn fx:id="nameColumn" text="Name" prefWidth="200"/>
            <TableColumn fx:id="statusColumn" text="Status" prefWidth="100"/>
        </columns>
    </TableView>

    <HBox spacing="10">
        <Button text="Verify selected" onAction="#handleVerify"/>
        <Button text="Refresh" onAction="#handleRefresh"/>
        <Button text="Back" onAction="#handleBack"/>
    </HBox>

    <Label fx:id="errorLabel" textFill="red" wrapText="true"/>
    <Label fx:id="infoLabel" textFill="green" wrapText="true"/>
</VBox>
