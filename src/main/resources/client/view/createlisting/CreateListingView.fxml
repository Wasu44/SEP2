<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TextArea?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.client.view.createlisting.CreateListingViewController"
      spacing="10" prefWidth="400">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <Label text="Create listing" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <Label text="Title"/>
    <TextField fx:id="titleField"/>

    <Label text="Description"/>
    <TextArea fx:id="descriptionField" prefRowCount="3"/>

    <Label text="Quantity"/>
    <TextField fx:id="quantityField"/>

    <Label text="Pickup window (e.g. Today 17:00-19:00)"/>
    <TextField fx:id="pickupWindowField"/>

    <Button text="Create" onAction="#handleCreate" maxWidth="Infinity"/>
    <Button text="Back" onAction="#handleBack" maxWidth="Infinity"/>

    <Label fx:id="errorLabel" textFill="red" wrapText="true"/>
    <Label fx:id="infoLabel" textFill="green" wrapText="true"/>
</VBox>
